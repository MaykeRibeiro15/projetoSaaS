# Application
NODE_ENV=development
PORT=3001
APP_NAME=Vitalle

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vitalle?schema=public

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# WhatsApp Business Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# PagBank
PAGBANK_API_URL=https://api.pagseguro.com
PAGBANK_TOKEN=your-pagbank-token
PAGBANK_WEBHOOK_SECRET=your-webhook-secret

# NFe
NFE_API_URL=https://api.nfe.io
NFE_API_KEY=your-nfe-api-key
NFE_COMPANY_ID=your-company-id

# Storage
SUPABASE_STORAGE_BUCKET=vitalle-storage

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100
